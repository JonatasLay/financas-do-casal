# Supabase — encontre em: supabase.com > seu projeto > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=cole_a_chave_anon_public_aqui
SUPABASE_SERVICE_ROLE_KEY=cole_a_service_role_key_aqui

# Anthropic — encontre em: console.anthropic.com > API Keys
# NUNCA use o prefixo NEXT_PUBLIC_ aqui — só o servidor pode ver essa chave!
ANTHROPIC_API_KEY=cole_a_chave_anthropic_aqui
